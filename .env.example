# =============================================================================
# Antares Resilience — Environment Variables
# All variables are OPTIONAL. The site renders and the contact form works
# without any of them (form falls back to a prefilled mailto: link).
# =============================================================================

# --- Email delivery (server-only) ------------------------------------------
# API key from resend.com. Required for the contact form to actually send.
# NEVER prefix with NEXT_PUBLIC_.
RESEND_API_KEY=

# Destination address that receives inquiries.
CONTACT_TO_EMAIL=signal@antaresresilience.com

# Optional. Defaults to: Antares Resilience <noreply@antaresresilience.com>
CONTACT_FROM_EMAIL=

# --- Public site config ----------------------------------------------------
# Canonical origin used for SEO, sitemap, OG URLs.
NEXT_PUBLIC_SITE_URL=https://antaresresilience.com

# Optional. If set, the layout injects the Plausible script. Omit to skip.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
